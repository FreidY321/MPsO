# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=MaturitniCetba

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=24h

# Server Configuration
PORT=3000
NODE_ENV=development

# CORS Configuration
CORS_ORIGIN=http://localhost:8080

# Mobile app scheme for Google OAuth Callback
MOBILE_APP_SCHEME=path_to_the_cetba_mobile_app

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Graduation Reading Settings
TOTAL_BOOKS_REQUIRED=20
MAX_BOOKS_PER_AUTHOR=2

# School information
SCHOOL_NAME="SPŠEI Ostrava"
SCHOOL_LOGO_URL=http://localhost:3000/logo-spsei.png
BOOK_LIST=url_seznamu_knih